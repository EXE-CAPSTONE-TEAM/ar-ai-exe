# Copy to deploy/.env on the VPS. This file is read by docker compose for the public web service.
APP_DOMAIN=your-domain.example.com
ACME_EMAIL=admin@your-domain.example.com
MARKETING_LOGIN_URL=https://kusshoes.vn/login

# 8 GB VPS profile for the self-contained 3D toolchain image.
# Provision the host with 8 GB RAM, 4-8 GB swap, 2-4 vCPU, and 40+ GB disk.
OPENMVS_REF=v2.4.0
OPENMVS_BUILD_JOBS=2
APP_RECONSTRUCTION_MAX_THREADS=2
BACKEND_CPUS=2.0
BACKEND_MEMORY_LIMIT=6g
BACKEND_MEMORY_SWAP_LIMIT=10g
WORKER_CPUS=1.0
WORKER_MEMORY_LIMIT=2g
WORKER_MEMORY_SWAP_LIMIT=4g
